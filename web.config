<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <system.webServer>
    <!-- Autorise les modules ASP.NET pour toutes les requêtes -->
    <modules runAllManagedModulesForAllRequests="true" />

    <rewrite>
      <rules>
        <!-- Règle 1 : Redirection permanente de .aspx vers l'URL propre (SEO friendly) -->
        <rule name="RedirectToCleanURL" stopProcessing="true">
          <match url="^(.*)\.aspx$" />
          <conditions>
            <add input="{REQUEST_METHOD}" pattern="^GET$" />
          </conditions>
          <action type="Redirect" url="{R:1}" appendQueryString="true" redirectType="Permanent" />
        </rule>

        <!-- Règle 3 : Réécriture interne (le serveur cherche le .aspx en arrière-plan) -->
        <rule name="RewriteCleanURL" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="{R:1}.aspx" />
        </rule>
      </rules>
    </rewrite>

    <!-- Page par défaut -->
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="auth/Login.aspx" />
      </files>
    </defaultDocument>
  </system.webServer>

  <connectionStrings>
    <add name="MaConnexion"
      connectionString="Server=MAHEFA_DESKTOP\SQLECOLE;Database=MONAPPECOLE2;User Id=sa;Password=admin123;"
      providerName="System.Data.SqlClient" />
  </connectionStrings>

  <appSettings>
    <add key="LicenceSecret" value="MON_APP_ECOLE_1512" />
    <add key="Version" value="2.1.13" />
  </appSettings>

  <system.web>
    <globalization requestEncoding="utf-8" responseEncoding="utf-8" culture="fr-FR" uiCulture="fr" />
    <compilation debug="true" targetFramework="4.8" />
    <customErrors mode="Off" />
    <authentication mode="None" />
    <sessionState mode="InProc" timeout="20" />
  </system.web>

</configuration>